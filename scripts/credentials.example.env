# Copy to ~/.config/lighthouse-cli/credentials.env (chmod 600) or project .env.lighthouse
# NEVER commit the real file.
#
# Load in your shell before login:
#   set -a && source ~/.config/lighthouse-cli/credentials.env && set +a
#   lighthouse auth login
#
LIGHTHOUSE_USERNAME=you@learner.manipal.edu
LIGHTHOUSE_PASSWORD=your-password-here
# Optional:
# LIGHTHOUSE_MFA_METHOD=auto
# LIGHTHOUSE_MFA_METHOD=choose
